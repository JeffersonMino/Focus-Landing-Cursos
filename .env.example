# API base
PORT=3000
CORS_ORIGIN=http://localhost:4200
DATA_DIR=/app/server/data
VISIT_DEBOUNCE_MS=30000

# URLs publicas usadas por pagos externos
# En local con PayPal real necesitas una URL publica tipo ngrok/cloudflare tunnel.
PUBLIC_BASE_URL=http://localhost:4200
FRONTEND_SUCCESS_URL=http://localhost:4200
API_PUBLIC_BASE_URL=http://localhost:3000

# Producto vendido. El backend usa estos valores y no confia en el precio enviado por Angular.
COURSE_PLAN_ID=dale-reset-taller-redes
COURSE_PRICE_USD=97
COURSE_DESCRIPTION=Taller Dale Reset - Sistema de ventas para redes sociales

# DeUna / DUNA Ecuador
# manual: usa un QR/link fijo temporal. direct: crea orden via API DeUna.
DEUNA_PROVIDER=manual
DEUNA_MODE=sandbox
DEUNA_API_BASE_URL=https://api.sandbox.deuna.io
DEUNA_API_KEY=
DEUNA_STORE_CODE=all
DEUNA_STATIC_QR_IMAGE_URL=
DEUNA_STATIC_DEEPLINK=
DEUNA_WEBHOOK_SECRET=

# PayPal Checkout para tarjeta global
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_BRAND_NAME=DaleReset
PAYPAL_WEBHOOK_SECRET=
